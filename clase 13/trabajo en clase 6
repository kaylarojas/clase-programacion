import json
import csv
import os

class FileConverter:
    # Atributo de clase para almacenar la instancia única
    _instance = None

    def __new__(cls):
        """
        Garantiza que solo exista una instancia de la clase (Patrón Singleton).
        """
        if cls._instance is None:
            # Crea la instancia si no existe
            cls._instance = super(FileConverter, cls).__new__(cls)
        return cls._instance

    def _obtener_ruta_absoluta(self, nombre_archivo):
        """
        Método privado para localizar el archivo en la misma carpeta que el script.
        Esto evita errores de 'FileNotFoundError' en Visual Studio Code.
        """
        directorio_actual = os.path.dirname(__file__)
        return os.path.join(directorio_actual, nombre_archivo)

    def convertFromJson(self, jsonFileStr):
        """
        Lee un archivo JSON y retorna su contenido como un diccionario de Python.
        """
        ruta_completa = self._obtener_ruta_absoluta(jsonFileStr)
        try:
            with open(ruta_completa, 'r', encoding='utf-8') as archivo:
                return json.load(archivo)
        except FileNotFoundError:
            return {"error": f"No se encontró el archivo JSON en: {ruta_completa}"}
        except Exception as e:
            return {"error": f"Error al procesar JSON: {str(e)}"}

    def convertFromCSV(self, csvFileStr):
        """
        Lee un archivo CSV y retorna su contenido como una estructura de diccionario.
        """
        ruta_completa = self._obtener_ruta_absoluta(csvFileStr)
        try:
            with open(ruta_completa, 'r', encoding='utf-8') as archivo:
                # DictReader usa la primera fila como llaves del diccionario
                lector = csv.DictReader(archivo)
                return [fila for fila in lector]
        except FileNotFoundError:
            return {"error": f"No se encontró el archivo CSV en: {ruta_completa}"}
        except Exception as e:
            return {"error": f"Error al procesar CSV: {str(e)}"}

# --- PRUEBA DE FUNCIONAMIENTO ---

if __name__ == "__main__":
    # Creamos el convertidor (Singleton)
    convertidor = FileConverter()

    # Probamos la carga de los archivos
    print("--- Cargando Datos de JSON ---")
    datos_json = convertidor.convertFromJson("datos.json")
    print(datos_json)

    print("\n--- Cargando Datos de CSV ---")
    datos_csv = convertidor.convertFromCSV("datos.csv")
    print(datos_csv)

    # Verificación de Singleton
    otra_instancia = FileConverter()
    print(f"\n¿Es la misma instancia? (Singleton): {convertidor is otra_instancia}")